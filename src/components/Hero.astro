---
---

<section id="hero" class="hero-section">
  <!-- Subtle Background Gridlines -->
  <div class="grid-lines" aria-hidden="true">
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
  </div>

  <!-- Ambient glow background gradients -->
  <div class="glow-orb glow-top" aria-hidden="true"></div>
  <div class="glow-orb glow-bottom" aria-hidden="true"></div>

  <div class="container hero-container">
    <h1 class="hero-title" aria-label="We Build Websites That Put Your Business On The Map">
      <div class="title-line">
        <span class="word-wrapper"><span class="word">We</span></span>
        <span class="word-wrapper"><span class="word">Build</span></span>
        <span class="word-wrapper"><span class="word">Websites</span></span>
      </div>
      <div class="title-line">
        <span class="word-wrapper"><span class="word">That</span></span>
        <span class="word-wrapper"><span class="word">Put</span></span>
        <span class="word-wrapper"><span class="word">Your</span></span>
        <span class="word-wrapper"><span class="word">Business</span></span>
      </div>
      <div class="title-line">
        <span class="word-wrapper"><span class="word">On</span></span>
        <span class="word-wrapper"><span class="word">The</span></span>
        <span class="word-wrapper">
          <span class="word accent-word">
            Map
            <span class="map-underline"></span>
          </span>
        </span>
      </div>
    </h1>

    <div class="hero-btn-wrapper">
      <a href="#work" class="btn-primary hero-btn">See Our Work</a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    height: 100vh; /* Full 100vh height */
    display: flex;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
    position: relative;
    background-color: var(--bg);
  }

  /* Gridlines */
  .grid-lines {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    pointer-events: none;
    z-index: 1;
  }

  .grid-line {
    border-right: 1px solid rgba(255, 255, 255, 0.02);
    height: 100%;
  }

  .grid-line:last-child {
    border-right: none;
  }

  /* Glow Orbs */
  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.1;
    pointer-events: none;
    z-index: 1;
    background-color: var(--accent);
  }

  .glow-top {
    width: 400px;
    height: 400px;
    top: -100px;
    right: 10%;
  }

  .glow-bottom {
    width: 500px;
    height: 500px;
    bottom: -150px;
    left: -100px;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Headline - clamp(48px, 10vw, 120px) */
  .hero-title {
    font-family: var(--font-headlines);
    font-size: clamp(48px, 10vw, 120px);
    line-height: 0.92;
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: 3.5rem;
    letter-spacing: -0.01em;
  }

  /* Stagger lines break */
  .title-line {
    overflow: hidden;
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.35em;
    padding-bottom: 0.1em;
  }

  .word-wrapper {
    overflow: hidden;
    display: inline-block;
    vertical-align: bottom;
  }

  .word {
    display: inline-block;
    opacity: 0;
  }

  .accent-word {
    color: var(--accent);
    position: relative;
    display: inline-block;
  }

  /* CSS Underline Animation on 'Map' */
  .map-underline {
    position: absolute;
    bottom: -0.03em;
    left: 0;
    width: 100%;
    height: 0.08em;
    background-color: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    animation: drawUnderline 1.2s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
    animation-delay: 1.2s; /* visible underline after stagger finishes */
  }

  @keyframes drawUnderline {
    to {
      transform: scaleX(1);
    }
  }

  /* CTA Button */
  .hero-btn {
    font-family: var(--font-body); /* Outfit font */
    background-color: var(--accent); /* Background var(--accent) */
    color: #FFFFFF; /* White text */
  }

  .hero-btn-wrapper {
    opacity: 0;
  }

  @media (max-width: 768px) {
    .title-line {
      column-gap: 0.25em;
    }
    .hero-title {
      margin-bottom: 2.5rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const initHeroAnimation = () => {
    // Stagger in each headline word from translateY(60px) opacity 0
    gsap.fromTo('.word', 
      {
        y: 60,
        opacity: 0
      }, 
      {
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.08,
        ease: 'power3.out'
      }
    );

    // Fade and slide up the CTA button wrapper
    gsap.fromTo('.hero-btn-wrapper',
      {
        y: 20,
        opacity: 0
      },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        delay: 1.0,
        ease: 'power2.out'
      }
    );
  };

  // Trigger animations
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroAnimation);
  } else {
    initHeroAnimation();
  }
</script>
