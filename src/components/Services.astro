---
const services = [
  {
    title: "Web Design & Development",
    desc: "From concept to launch — we build sharp, functional websites tailored to your business."
  },
  {
    title: "Website Revamps",
    desc: "Got an outdated site? We strip it back and rebuild it into something worth showing off."
  },
  {
    title: "Web Deployment",
    desc: "Already have a site? We handle the technical side of getting it live, fast and properly."
  }
];
---

<section id="services" class="services-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">What We Do</h2>
    </div>
    
    <div class="services-grid">
      {services.map(service => (
        <div class="service-card">
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: var(--bg);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 10rem 0;
  }

  .section-header {
    margin-bottom: 5rem;
    max-width: 600px;
  }

  .section-tag {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.15em;
    display: inline-block;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
  }

  .section-title {
    font-family: var(--font-headlines);
    /* Heading: "What We Do" Bebas Neue, clamp(36px, 6vw, 72px), var(--text-primary) */
    font-size: clamp(36px, 6vw, 72px);
    line-height: 1;
    color: var(--text-primary);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* 3 columns on desktop, 1 column on mobile */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .service-card {
    background-color: var(--surface); /* background var(--surface) */
    border-top: 3px solid var(--accent); /* 3px crimson top border */
    border-left: 1px solid rgba(255, 255, 255, 0.01);
    border-right: 1px solid rgba(255, 255, 255, 0.01);
    border-bottom: 1px solid rgba(255, 255, 255, 0.01);
    padding: 24px; /* 24px padding */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-height: 250px;
    transition: var(--transition-smooth);
  }

  .service-card:hover {
    border-top-color: var(--accent-hover);
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(204, 16, 51, 0.1);
  }

  .service-title {
    font-family: var(--font-headlines); /* Card titles in Bebas Neue */
    font-size: 2.2rem;
    line-height: 1.1;
    color: var(--text-primary);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    letter-spacing: 0.02em;
  }

  .service-desc {
    font-family: var(--font-body); /* descriptions in Outfit */
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Responsive breakpoints */
  @media (max-width: 1024px) {
    .services-grid {
      gap: 1.5rem;
    }
    .service-card {
      min-height: auto;
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr; /* 1 column on mobile */
      gap: 2rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initScrollTrigger = () => {
    // GSAP ScrollTrigger: staggered fade + translateY(40px) on scroll into view
    gsap.fromTo('.service-card',
      {
        opacity: 0,
        y: 40
      },
      {
        scrollTrigger: {
          trigger: '.services-grid',
          start: 'top 85%',
          toggleActions: 'play none none none'
        },
        opacity: 1,
        y: 0,
        duration: 1.0,
        stagger: 0.15,
        ease: 'power3.out'
      }
    );
  };

  // Trigger animations
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollTrigger);
  } else {
    initScrollTrigger();
  }
</script>
