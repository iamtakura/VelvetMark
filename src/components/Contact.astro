---
const socialLinks = [
  { name: "Work", url: "#work" },
  { name: "Services", url: "#services" },
  { name: "Process", url: "#process" },
  { name: "Pricing", url: "#pricing" },
  { name: "Contact", url: "#contact" }
];

// Replaced with actual Zimbabwean format number for Harare
const contactNumber = "263770000000";
const whatsappText = "Hi Velvetmark, I'm interested in your web services.";
const whatsappUrl = `https://wa.me/${contactNumber}?text=${encodeURIComponent(whatsappText)}`;
---

<section id="contact" class="contact-section">
  <div class="container contact-container">
    <div class="contact-content-box">
      <!-- Heading: splits and staggers in word by word on scroll -->
      <h2 class="section-title contact-heading" id="contact-heading" aria-label="Let's Put You On The Map">
        <span class="contact-word">Let's</span>
        <span class="contact-word">Put</span>
        <span class="contact-word">You</span>
        <span class="contact-word">On</span>
        <span class="contact-word">The</span>
        <span class="contact-word accent-highlight">Map</span>
      </h2>
      
      <!-- Subheading in Outfit -->
      <p class="contact-subheading">Ready to build something great? Let's talk.</p>
      
      <!-- Single CTA button: Chat on WhatsApp -->
      <div class="cta-btn-wrapper">
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="whatsapp-btn">
          <!-- WhatsApp SVG Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="whatsapp-icon">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.725 1.45 5.515 0 9.961-4.45 9.964-9.97 0-2.673-1.04-5.186-2.93-7.078-1.89-1.891-4.4-2.933-7.07-2.934-5.518 0-9.97 4.451-9.974 9.972-.001 1.716.467 3.391 1.354 4.869l-.973 3.554 3.638-.953zM16.924 13.91c-.267-.134-1.583-.78-1.827-.869-.243-.088-.422-.133-.6.134-.179.266-.69.869-.844 1.046-.156.177-.31.199-.577.065-.267-.134-1.13-.417-2.152-1.328-.795-.71-1.332-1.587-1.488-1.854-.156-.266-.017-.409.117-.542.121-.12.267-.31.401-.466.134-.155.179-.266.267-.442.089-.177.044-.332-.022-.466-.067-.134-.6-1.446-.822-1.98-.216-.52-.455-.45-.6-.458-.133-.007-.288-.008-.443-.008-.155 0-.409.058-.621.288-.213.23-.81.792-.81 1.932 0 1.139.828 2.24 1.04 2.532.213.292 2.87 4.394 6.776 5.892 2.115.811 3.23 1.025 4.36.839 1.02-.167 1.83-.699 2.05-1.318.22-.619.22-1.15.155-1.258-.065-.108-.243-.197-.51-.331z"/>
          </svg>
          <span>Chat on WhatsApp</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Rebuilt Footer -->
  <footer class="footer-block">
    <div class="container footer-content">
      <!-- Row 1 -->
      <div class="footer-row footer-row-1">
        <span class="footer-logo">Velvetmark</span>
        <div class="footer-nav">
          {socialLinks.map(link => (
            <a href={link.url} class="footer-nav-link">{link.name}</a>
          ))}
        </div>
      </div>
      
      <!-- Row 2 -->
      <div class="footer-row footer-row-2">
        <span class="footer-copy">&copy; 2025 Velvetmark. All rights reserved.</span>
        <span class="footer-location">Harare, Zimbabwe</span>
      </div>
    </div>
  </footer>
</section>

<style>
  .contact-section {
    background-color: var(--surface); /* var(--surface) to differentiate */
    padding-top: clamp(80px, 12vw, 150px);
    padding-bottom: 0; /* Let footer handle bottom spacing */
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    width: 100%;
  }

  .contact-container {
    padding-bottom: clamp(80px, 12vw, 150px);
  }

  .contact-content-box {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .section-tag {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.15em;
    display: inline-block;
    text-transform: uppercase;
  }

  /* Large heading: clamp(36px, 8vw, 96px) */
  .contact-heading {
    font-family: var(--font-headlines);
    font-size: clamp(36px, 8vw, 96px);
    line-height: 0.95;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    column-gap: 0.3em;
    row-gap: 0.1em;
  }

  /* Headings thin crimson dot accent consistency (inherited from global, but custom positioning here) */
  .contact-heading::after {
    display: none; /* Turn off inline block dot since it breaks flex flow */
  }

  .contact-word {
    display: inline-block;
    opacity: 0;
  }

  .accent-highlight {
    color: var(--accent);
    position: relative;
  }

  .accent-highlight::after {
    content: '';
    display: inline-block;
    width: clamp(6px, 1.2vw, 12px);
    height: clamp(6px, 1.2vw, 12px);
    background-color: var(--accent);
    margin-left: 0.2rem;
    vertical-align: baseline;
  }

  /* Subheading: Outfit, var(--text-muted) */
  .contact-subheading {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--text-muted);
    font-weight: 400;
  }

  .cta-btn-wrapper {
    margin-top: 1rem;
    opacity: 0;
    transform: translateY(20px);
  }

  /* WhatsApp button */
  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background-color: #25D366; /* WhatsApp green */
    color: #FFFFFF; /* White text */
    font-family: var(--font-body); /* Outfit font */
    font-weight: 700; /* bold */
    font-size: 1.05rem;
    text-decoration: none;
    padding: 1.1rem 2.8rem;
    border-radius: 0; /* Editorial look */
    transition: var(--transition-smooth);
    box-shadow: 0 5px 15px rgba(37, 211, 102, 0.2);
  }

  /* On hover: slight brightness increase, subtle scale 1.02 */
  .whatsapp-btn:hover {
    filter: brightness(1.08);
    transform: scale(1.02);
    box-shadow: 0 10px 25px rgba(37, 211, 102, 0.35);
  }

  .whatsapp-icon {
    flex-shrink: 0;
  }

  /* Rebuilt Footer */
  .footer-block {
    background-color: #080808; /* Background #080808 */
    border-top: 1px solid var(--accent); /* Thin crimson top border */
    padding: 4rem 0;
    width: 100%;
    margin-top: 5rem;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding: 0 2.5rem;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  /* Row 1 Layout */
  .footer-logo {
    font-family: var(--font-headlines);
    font-size: 1.8rem;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-nav {
    display: flex;
    gap: 2rem;
  }

  .footer-nav-link {
    font-family: var(--font-body); /* Outfit */
    font-size: 0.85rem; /* small */
    color: var(--text-muted); /* var(--text-muted) */
    text-decoration: none;
    transition: var(--transition-fast);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-nav-link:hover {
    color: var(--accent); /* crimson on hover */
  }

  /* Row 2 Layout */
  .footer-copy {
    font-family: var(--font-body); /* Outfit */
    font-size: 0.85rem; /* small */
    color: var(--text-muted); /* var(--text-muted) */
  }

  .footer-location {
    font-family: var(--font-body); /* Outfit */
    font-size: 0.85rem; /* small */
    color: var(--text-muted); /* var(--text-muted) */
    letter-spacing: 0.05em;
  }

  /* Responsive styling */
  @media (max-width: 768px) {
    .footer-content {
      padding: 0 1.5rem;
      gap: 2rem;
    }
    
    .footer-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .footer-row-2 {
      flex-direction: column-reverse;
      gap: 0.8rem;
    }

    .footer-nav {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initScrollTrigger = () => {
    // GSAP ScrollTrigger: heading splits and staggers in word by word on scroll
    gsap.fromTo('.contact-word',
      {
        opacity: 0,
        y: 40
      },
      {
        scrollTrigger: {
          trigger: '#contact-heading',
          start: 'top 85%',
          toggleActions: 'play none none none'
        },
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: 'power3.out'
      }
    );

    // Stagger button in too
    gsap.fromTo('.cta-btn-wrapper',
      {
        opacity: 0,
        y: 20
      },
      {
        scrollTrigger: {
          trigger: '#contact-heading',
          start: 'top 85%',
          toggleActions: 'play none none none'
        },
        opacity: 1,
        y: 0,
        duration: 0.8,
        delay: 0.6,
        ease: 'power2.out'
      }
    );
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollTrigger);
  } else {
    initScrollTrigger();
  }
</script>
